{
    "langrev": "1",
    "warnings": ["no-unused"],
    "dependency-search-paths": ["lib"],
    "dependencies": ["raylib55", "nk", "raygui", "ev", "sqlite3"],
    "authors": ["LowByteFox"],
    "version": "0.3.0",
    "sources": ["src/**"],
    "test-sources": ["test/**"],
    "output": "build",
    "targets": {
        "OpenPNGStudio-linux-x64": {
            "type": "static-lib",
            "name": "libOpenPNGStudio"
        },
        "OpenPNGStudio-windows-x64": {
            "type": "static-lib",
            "name": "libOpenPNGStudio"
        },
        "opng": {
            "type": "executable",
            "dependencies-override": ["sqlite3"],
            "linked-libraries-override": ["sqlite3"],
            "sources-override": ["src/opng/**"],
            "features": ["OPNG_STANDALONE"],
            "test-sources-override": ["test/opng/**"]
        }
    },
    "cpu": "generic",
    "fp-math": "fast",
    "opt": "O0",
    "features": [],
    "quiet": true
}
